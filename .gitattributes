# Force LF for everything that runs on / is parsed by the Linux host. CRLF in a shell
# script or YAML breaks on the box (bash chokes on \r). Authored on Windows, runs on Ubuntu.
* text=auto eol=lf
*.sh        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.j2        text eol=lf
*.cfg       text eol=lf
*.ini       text eol=lf
Makefile    text eol=lf

# Binary signing keys — must NEVER get line-ending normalization (would corrupt them).
*.gpg       binary
roles/apt_repos/files/keyrings/** binary
